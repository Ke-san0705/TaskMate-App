# Development overrides only. Official desktop builds should use
# renderer/config/publicRuntimeConfig.js for the public Supabase URL/key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Standalone Google Calendar OAuth fallback for email/password users or local testing.
# The preferred public flow is Supabase Google login with Calendar scopes.
GOOGLE_OAUTH_CLIENT_ID=
